# Copy this file to `.env` and fill in real values. Never commit `.env`.

# Google Gemini API key — used for AI nutrition lookup (text & image).
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Supabase Postgres connection string (hosted database).
# Use the "Transaction pooler" string from the Supabase dashboard:
#   Project → Connect → Transaction pooler (port 6543).
# Replace [YOUR-PASSWORD] with your database password. Works locally and on Vercel.
DATABASE_URL=postgresql://postgres.xxxxxxxx:[YOUR-PASSWORD]@aws-0-xx-xxxx-x.pooler.supabase.com:6543/postgres
